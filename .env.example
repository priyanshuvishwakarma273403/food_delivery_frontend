# Tomato App - Environment Variables
# Copy this file to .env.local for local development, and set these in your production environment (Vercel/Netlify/Railway)

# API URL
# Local: http://localhost:8080/api/v1
# Production: https://your-backend-production-url.com/api/v1
VITE_API_BASE_URL=http://localhost:8080/api/v1

# WebSockets URL
# Local: ws://localhost:8080/ws
# Production: wss://your-backend-production-url.com/ws
VITE_WS_URL=ws://localhost:8080/ws

# Google OAuth Client ID 
# Get this from Google Cloud Console Dashboard -> APIs & Services -> Credentials
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
